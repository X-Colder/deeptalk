page {
  min-height: 100vh;
  background: #f5f7f4;
  color: #25312f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  letter-spacing: 0;
}

view,
text,
button,
textarea,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.2;
  font-size: 28rpx;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 52rpx;
}

.topbar {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.brand {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.brand-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #223835;
}

.brand-note {
  max-width: 500rpx;
  color: #6d7772;
  font-size: 24rpx;
  line-height: 1.55;
}

.section-title {
  margin: 34rpx 0 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #263b37;
}

.subtle {
  color: #79827d;
}

.card {
  border: 1rpx solid #dfe7e1;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(55, 66, 60, 0.05);
}

.primary-button,
.secondary-button,
.quiet-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 0 28rpx;
  border-radius: 8rpx;
  font-weight: 650;
}

.primary-button {
  background: #26413c;
  color: #fffdf8;
}

.secondary-button {
  border: 1rpx solid #bcc9c3;
  background: #f4f7f5;
  color: #28453f;
}

.quiet-button {
  color: #45534f;
  background: #e7ede9;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  min-height: 44rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #eef3ee;
  color: #486058;
  font-size: 22rpx;
  line-height: 1.2;
}

.tag.warn {
  background: #f4eadc;
  color: #7a5c2a;
}

.tag.blue {
  background: #eaf0f4;
  color: #3b5362;
}

.divider {
  height: 1rpx;
  background: #dde6e0;
}

.textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe7e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #26312e;
  font-size: 28rpx;
  line-height: 1.7;
}

.muted-box {
  padding: 20rpx;
  border-radius: 8rpx;
  background: #e9eeeb;
  color: #68736e;
  font-size: 24rpx;
  line-height: 1.55;
}
