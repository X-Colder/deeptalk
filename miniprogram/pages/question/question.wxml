<view class="page question-page">
  <view wx:if="{{loading}}" class="muted-box">正在读取问题。</view>

  <block wx:if="{{question}}">
    <view class="question-main card">
      <view class="question-meta">
        <text>{{question.mood}} · {{question.visibilityLabel}}</text>
        <text>{{question.createdAt}}</text>
      </view>
      <view class="asker-box">
        <view class="asker-name">提问者：{{question.authorDisplay}}</view>
        <view class="asker-note">{{question.authorPortrait}}</view>
      </view>
      <view class="question-title">{{question.title}}</view>
      <view class="question-intro">{{question.intro}}</view>
      <view class="tag-row">
        <text wx:for="{{question.communityTags}}" wx:key="*this" class="tag blue">{{item}}</text>
      </view>
    </view>

    <view class="section-title">回答即名片</view>
    <view class="answer-card card">
      <view class="profile-line">
        <view class="avatar-mark">{{question.avatarInitial}}</view>
        <view>
          <view class="answer-name">{{question.featuredAnswer.userName}}</view>
          <view class="answer-style">{{question.featuredAnswer.style}}</view>
        </view>
      </view>
      <view class="answer-body">{{question.featuredAnswer.text}}</view>
      <view class="tag-row answer-tags">
        <text wx:for="{{question.featuredAnswer.communityTags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="score-grid">
        <view class="score-item">
          <text class="score-value">具体</text>
          <text class="score-label">不是空泛表态</text>
        </view>
        <view class="score-item">
          <text class="score-value">自省</text>
          <text class="score-label">能反观自己</text>
        </view>
        <view class="score-item">
          <text class="score-value">尊重</text>
          <text class="score-label">保留他人边界</text>
        </view>
      </view>
    </view>

    <view class="section-title">读者评价</view>
    <view class="evaluation-card card">
      <view class="evaluation-note">标签不由回答者自选，而由读者评价和内容分析逐步形成。</view>
      <view class="tag-row">
        <button
          wx:for="{{evaluationTags}}"
          wx:key="name"
          class="tag tag-button {{item.selected ? 'selected' : ''}}"
          data-name="{{item.name}}"
          bindtap="toggleEvaluation"
        >
          {{item.name}}
        </button>
      </view>
      <button class="secondary-button" bindtap="submitEvaluation">提交评价</button>
    </view>

    <view class="section-title">申请继续深聊</view>
    <view class="invite-card card">
      <textarea
        class="textarea invite-input"
        maxlength="400"
        value="{{inviteReason}}"
        placeholder="写下你欣赏这段表达的原因，以及你想继续聊的具体问题。"
        bindinput="onReasonInput"
      />
      <view class="invite-count {{inviteReasonLength >= minInviteReasonLength ? 'ready' : ''}}">
        {{inviteReasonLength}} / {{minInviteReasonLength}} 字
      </view>
      <button class="primary-button" bindtap="sendInvite">发送同频邀请</button>
      <button class="secondary-button" bindtap="writeAnswer">回答这个提问者</button>
    </view>

    <view class="section-title">媒介边界</view>
    <view class="media-card card">
      <view
        wx:for="{{mediaPolicy}}"
        wx:key="name"
        class="media-row {{item.active ? '' : 'locked'}}"
      >
        <view>
          <view class="media-name">{{item.name}}</view>
          <view class="media-desc">{{item.desc}}</view>
        </view>
        <text class="media-state">{{item.active ? '开放' : '待解锁'}}</text>
      </view>
    </view>
  </block>
</view>
