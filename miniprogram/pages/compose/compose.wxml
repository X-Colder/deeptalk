<view class="page compose-page">
  <view class="topbar">
    <view class="brand">
      <text class="brand-name">认真表达</text>
      <text class="brand-note">这里先看你怎样思考，再决定谁值得靠近。</text>
    </view>
  </view>

  <view class="mode-tabs">
    <button
      wx:for="{{modes}}"
      wx:key="*this"
      class="mode-tab {{activeMode === item ? 'active' : ''}}"
      data-mode="{{item}}"
      bindtap="switchMode"
    >
      {{item}}
    </button>
  </view>

  <view class="compose-card card">
    <input
      class="topic-input"
      maxlength="60"
      value="{{topic}}"
      placeholder="{{activeMode === '提出问题' ? '写下一个值得讨论的问题' : '请先从问题详情选择提问者'}}"
      bindinput="onTopicInput"
    />
    <view wx:if="{{activeMode === '回答问题' && selectedQuestion}}" class="selected-question">
      <view class="selected-title">正在回答：{{selectedQuestion.authorName}}</view>
      <view class="selected-desc">{{selectedQuestion.title}}</view>
    </view>
    <textarea
      class="textarea main-textarea"
      maxlength="1200"
      value="{{content}}"
      placeholder="请写具体经历、真实判断和你愿意公开的边界。避免空泛表态、攻击他人或用真诚包装冒犯。"
      bindinput="onContentInput"
    />

    <view class="counter-row">
      <text>{{content.length}} / 1200</text>
      <text>至少 80 字</text>
    </view>
  </view>

  <view wx:if="{{activeMode === '提出问题'}}" class="section-title">问题可见性</view>
  <view wx:if="{{activeMode === '提出问题'}}" class="visibility-card card">
    <button
      wx:for="{{visibilityOptions}}"
      wx:key="key"
      class="visibility-option {{visibility === item.key ? 'active' : ''}}"
      data-visibility="{{item.key}}"
      bindtap="selectVisibility"
    >
      <view class="visibility-name">{{item.name}}</view>
      <view class="visibility-desc">{{item.desc}}</view>
    </button>
  </view>

  <view class="section-title">标签与画像</view>
  <view class="muted-box">
    表达质量标签不由自己选择。发布后会根据读者评价、被邀请情况和问答内容，逐步形成你的沟通画像。
  </view>

  <view class="section-title">多媒体接入</view>
  <view class="media-tools card">
    <button
      wx:for="{{mediaItems}}"
      wx:key="type"
      class="media-tool {{item.enabled ? '' : 'disabled'}}"
      data-enabled="{{item.enabled}}"
      bindtap="chooseImage"
    >
      <view class="media-label">{{item.label}}</view>
      <view class="media-hint">{{item.hint}}</view>
    </button>
  </view>

  <button class="primary-button submit-button" bindtap="submit">提交表达</button>
</view>
